# Public template only.
# Copy to .env locally and adjust for your own environment.
# Do not commit .env.

# General
ORG_LABEL=example-org
ENVIRONMENT=lab

# Loki
LOKI_URL=http://10.0.0.10:3100
LOKI_PUSH_URL=http://10.0.0.10:3100/loki/api/v1/push

# Grafana
GRAFANA_URL=https://logs.example.org
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Telegram
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_CHAT_ID=change-me

# CrowdSec
CROWDSEC_LAPI_URL=http://127.0.0.1:8080
CROWDSEC_CENTRAL_LAPI_URL=http://10.0.0.10:8080

# SSH deployment
SSH_USER=ubuntu
SSH_PORT=22
SSH_CONNECT_TIMEOUT=10